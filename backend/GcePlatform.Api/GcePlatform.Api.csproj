<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
<Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>GcePlatform.Api</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- SQL Server driver with Active Directory / AAD auth support -->
    <PackageReference Include="Microsoft.Data.SqlClient" Version="5.2.1" />
    <!-- Lightweight SQL ↔ object mapper -->
    <PackageReference Include="Dapper" Version="2.1.35" />
    <!-- Azure AD JWT Bearer token validation (2.x targets net6.0) -->
    <PackageReference Include="Microsoft.Identity.Web" Version="2.21.1" />
    <!-- DefaultAzureCredential for local dev (uses az login) -->
    <PackageReference Include="Azure.Identity" Version="1.12.0" />
    <!-- Structured logging (7.x targets net6.0) -->
    <PackageReference Include="Serilog.AspNetCore" Version="7.0.0" />
    <PackageReference Include="Serilog.Sinks.Console" Version="5.0.1" />
  </ItemGroup>

</Project>
